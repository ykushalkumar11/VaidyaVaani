{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "client/src/*"
            ],
            "@shared/*": [
                "shared/*"
            ]
        }
    },
    "include": [
        "client/src/**/*",
        "server/**/*",
        "shared/**/*",
        "script/**/*"
    ]
}